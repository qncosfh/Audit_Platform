# Platform Development Environment Configuration

# ==================== 数据库配置 ====================
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxx
POSTGRES_DB=platform
POSTGRES_PORT=5432

# ==================== 后端配置 ====================
BACKEND_PORT=8080

# 数据库连接URL（PostgreSQL不暴露端口，通过localhost访问）
DATABASE_URL=postgres://xxx:xxx@localhost:5432/platform?sslmode=disable


# JWT密钥
JWT_SECRET=xxx
JWT_EXPIRE_HOUR=xx

# 环境配置（生产环境使用PostgreSQL）
ENVIRONMENT=production

# 上传文件最大大小（字节）
MAX_UPLOAD_SIZE=10485760000
# 上传目录
UPLOAD_PATH=./sandbox

# ==================== 邮件服务配置 ====================
SMTP_SERVER=smtp.xx.cn
SMTP_PORT=465
SMTP_USERNAME=xx@xx.cn
SMTP_PASSWORD=xxx
FROM_EMAIL=xx@xx.cn
TO_EMAIL=xx@xx.cn

# ==================== 前端配置 ====================
FRONTEND_PORT=4416
